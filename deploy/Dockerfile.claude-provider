FROM node:20-bookworm-slim

WORKDIR /srv

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install --omit=dev express @anthropic-ai/claude-agent-sdk
RUN npm install -g @anthropic-ai/claude-code

COPY ../backend /srv/backend
COPY ../services/providers/claude-server.js /srv/services/providers/claude-server.js

WORKDIR /workspace

ENV PORT=3102
ENV CLAUDE_WORKDIR=/workspace
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

EXPOSE 3102

CMD ["node", "/srv/services/providers/claude-server.js"]
